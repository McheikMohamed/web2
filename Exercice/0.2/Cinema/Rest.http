@baseurl = http://localhost:3000

### Read all Film
GET {{baseurl}}/cinema

### Get film with minimal-duration
GET {{baseurl}}/cinema/?minimumDuration=140

### Get film from ID
GET {{baseurl}}/cinema/7

###Post new Film
POST {{baseurl}}/cinema/
Content-Type: application/json

{
    "title" : "Les aventures de Bernard",
    "duration" : 155,
    "budget" : 1.3,
    "link" : "www.Kinepolice/Les-aventures-de-Bernard"
}


###DELETE film
DELETE {{baseurl}}/cinema/1
